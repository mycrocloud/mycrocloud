{
  "mcpServers": {
    "neon": {
      "command": "npx",
      "args": [
        "-y",
        "@neondatabase/mcp-server-neon",
        "start"
      ],
      "env": {
        "NEON_API_KEY": "<your-neon-api-key>"
      }
    },
    "grafana": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "GRAFANA_URL",
        "-e",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN",
        "mcp/grafana",
        "-t",
        "stdio"
      ],
      "env": {
        "GRAFANA_URL": "https://mycrocloud.grafana.net",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": ""
      }
    }
  }
}
