global:
  scrape_interval: 15s

scrape_configs:
  - job_name: node
    static_configs:
      - targets: ['localhost:9100']

  - job_name: nginx
    static_configs:
      - targets: ['localhost:9113']

remote_write:
  - url: {{ secrets.PROMETHEUS_URL }}
    basic_auth:
      username: {{ secrets.PROMETHEUS_USERNAME }}
      password: {{ secrets.GRAFANA_API_KEY }}
