discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "containers" {
  targets = discovery.docker.containers.targets

  // Default service label to container name
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/?(.*)"
    target_label  = "service"
  }

  // Override with logging.service label if set
  rule {
    source_labels = ["__meta_docker_container_label_logging_service"]
    regex         = "(.+)"
    target_label  = "service"
  }

  rule {
    source_labels = ["__meta_docker_container_label_logging_component"]
    regex         = "(.+)"
    target_label  = "component"
  }

  // Drop ephemeral containers (spa builder and function invoker)
  rule {
    source_labels = ["__meta_docker_container_image"]
    regex         = "ghcr.io/mycrocloud/mycrocloud-(spa-builder|function-invoker):.*"
    action        = "drop"
  }
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.containers.output
  forward_to = [loki.process.logs.receiver]
}

loki.process "logs" {
  // Drop cAdvisor warnings about ephemeral containers (function-invoker, spa-builder)
  // that get cleaned up before cAdvisor can read their layerdb entries
  stage.match {
    selector = "{service=\"cadvisor\"}"
    stage.drop {
      expression = "failed to identify the read-write layer ID"
    }
  }

  // Only process ASP.NET services that output JSON logs
  stage.match {
    selector = "{service=~\"api|db-migrator|gateway\"}"

    // Parse JSON fields
    stage.json {
      expressions = {
        level    = "LogLevel",
        category = "Category",
        message  = "Message",
      }
    }

    // Map ASP.NET LogLevel to Loki level values
    stage.template {
      source   = "level"
      template = "{% raw %}{{ if eq .Value \"Trace\" }}debug{{ else if eq .Value \"Debug\" }}debug{{ else if eq .Value \"Information\" }}info{{ else if eq .Value \"Warning\" }}warn{{ else if eq .Value \"Error\" }}error{{ else if eq .Value \"Critical\" }}critical{{ else }}{{ .Value }}{{ end }}{% endraw %}"
    }

    stage.labels {
      values = {
        level = "",
      }
    }

    // Rewrite log line to readable format
    stage.template {
      source   = "output"
      template = "{% raw %}{{ if .message }}{{ .level }} [{{ .category }}] {{ .message }}{{ end }}{% endraw %}"
    }

    stage.output {
      source = "output"
    }
  }

  forward_to = [loki.write.grafana_cloud.receiver]
}

loki.write "grafana_cloud" {
  endpoint {
    url = "https://logs-prod-017.grafana.net/loki/api/v1/push"

    basic_auth {
      username = "1498726"
      password = "{{ secrets.grafana_cloud_api_key }}"
    }
  }
}
