global:
  scrape_interval: 15s

scrape_configs:
  - job_name: node
    static_configs:
      - targets: ['localhost:9100']

  - job_name: cadvisor
    static_configs:
      - targets: ['localhost:8080']


remote_write:
  - url: https://prometheus-us-central1.grafana.net/api/prom/push
    basic_auth:
      username: "3006102"
      password: {{ secrets.grafana_api_key }}
